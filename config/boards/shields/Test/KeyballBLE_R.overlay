/* ===============================
 * KeyballBLE_R.overlay（全置き換え / layer16=キーscroll前提）
 *  - WHEEL/HWHEEL 端数繰り越し（常時）
 *  - SCROLL(=layer 5) では通常スクロール（scroll-layers=5）
 *  - SCROLL_SNAP(=layer 15) は scroll-snap（現状維持：5がONの時に効く）
 *  - ジェスチャ中は drop_all で REL を止める（現状維持）
 *  - 追加：SNIPE(=layer 16) は REL_X/Y のみ減速（スクロールはキー側で実施）
 * =============================== */

#include "KeyballBLE.dtsi"

#include <input/processors.dtsi>
#include <scroll-snap.dtsi>
#include <mouse-gesture.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>

&default_transform { col-offset = <6>; };

&kscan0 {
    col-gpios = <&xiao_d 10 GPIO_ACTIVE_HIGH> , <&xiao_d 9 GPIO_ACTIVE_HIGH> , <&xiao_d 8 GPIO_ACTIVE_HIGH> , <&xiao_d 7 GPIO_ACTIVE_HIGH> , <&gpio0 10 GPIO_ACTIVE_HIGH>;
};

/ {
    input_processors {
        tb_wheel_rema: tb_wheel_rema { compatible = "zmk,input-processor-scaler"; #input-processor-cells = <2>; type = <INPUT_EV_REL>; codes = <INPUT_REL_WHEEL>; track-remainders; };
        tb_hwheel_rema: tb_hwheel_rema { compatible = "zmk,input-processor-scaler"; #input-processor-cells = <2>; type = <INPUT_EV_REL>; codes = <INPUT_REL_HWHEEL>; track-remainders; };

        tb_drop_all: tb_drop_all { compatible = "zmk,input-processor-scaler"; #input-processor-cells = <2>; type = <INPUT_EV_REL>; codes = <INPUT_REL_X INPUT_REL_Y INPUT_REL_WHEEL INPUT_REL_HWHEEL>; };

        /* layer15 用：カーソルだけ減速（例：1/4） */
        tb_snipe_xy: tb_snipe_xy { compatible = "zmk,input-processor-scaler"; #input-processor-cells = <2>; type = <INPUT_EV_REL>; codes = <INPUT_REL_X INPUT_REL_Y>; };

        zip_mouse_gesture_l11: zip_mouse_gesture_l11 { compatible = "zmk,input-processor-mouse-gesture"; #input-processor-cells = <0>; stroke-size = <60>; movement-threshold = <6>; idle-timeout-ms = <110>; gesture-cooldown-ms = <130>; enable-eager-mode; up { pattern = <GESTURE_UP>; bindings = <&mm_l11_up>; }; down { pattern = <GESTURE_DOWN>; bindings = <&mm_l11_down>; }; left { pattern = <GESTURE_LEFT>; bindings = <&mm_l11_left>; }; right { pattern = <GESTURE_RIGHT>; bindings = <&mm_l11_right>; }; };
        zip_mouse_gesture_l12: zip_mouse_gesture_l12 { compatible = "zmk,input-processor-mouse-gesture"; #input-processor-cells = <0>; stroke-size = <60>; movement-threshold = <6>; idle-timeout-ms = <110>; gesture-cooldown-ms = <130>; enable-eager-mode; up { pattern = <GESTURE_UP>; bindings = <&mm_l12_up>; }; down { pattern = <GESTURE_DOWN>; bindings = <&mm_l12_down>; }; left { pattern = <GESTURE_LEFT>; bindings = <&mm_l12_left>; }; right { pattern = <GESTURE_RIGHT>; bindings = <&mm_l12_right>; }; };
        zip_mouse_gesture_l13: zip_mouse_gesture_l13 { compatible = "zmk,input-processor-mouse-gesture"; #input-processor-cells = <0>; stroke-size = <60>; movement-threshold = <6>; idle-timeout-ms = <110>; gesture-cooldown-ms = <130>; enable-eager-mode; up { pattern = <GESTURE_UP>; bindings = <&mm_l13_up>; }; down { pattern = <GESTURE_DOWN>; bindings = <&mm_l13_down>; }; left { pattern = <GESTURE_LEFT>; bindings = <&mm_l13_left>; }; right { pattern = <GESTURE_RIGHT>; bindings = <&mm_l13_right>; }; };
        zip_mouse_gesture_l14: zip_mouse_gesture_l14 { compatible = "zmk,input-processor-mouse-gesture"; #input-processor-cells = <0>; stroke-size = <60>; movement-threshold = <6>; idle-timeout-ms = <110>; gesture-cooldown-ms = <130>; enable-eager-mode; up { pattern = <GESTURE_UP>; bindings = <&mm_l14_up>; }; down { pattern = <GESTURE_DOWN>; bindings = <&mm_l14_down>; }; left { pattern = <GESTURE_LEFT>; bindings = <&mm_l14_left>; }; right { pattern = <GESTURE_RIGHT>; bindings = <&mm_l14_right>; }; };

        zip_mouse_gesture_l7: zip_mouse_gesture_l7 { compatible = "zmk,input-processor-mouse-gesture"; #input-processor-cells = <0>; stroke-size = <60>; movement-threshold = <6>; idle-timeout-ms = <110>; gesture-cooldown-ms = <130>; enable-eager-mode; up { pattern = <GESTURE_UP>; bindings = <&mm_l7_up>; }; down { pattern = <GESTURE_DOWN>; bindings = <&mm_l7_down>; }; left { pattern = <GESTURE_LEFT>; bindings = <&mm_l7_left>; }; right { pattern = <GESTURE_RIGHT>; bindings = <&mm_l7_right>; }; };

        zip_mouse_gesture_l1: zip_mouse_gesture_l1 { compatible = "zmk,input-processor-mouse-gesture"; #input-processor-cells = <0>; stroke-size = <60>; movement-threshold = <6>; idle-timeout-ms = <110>; gesture-cooldown-ms = <130>; enable-eager-mode; up { pattern = <GESTURE_UP>; bindings = <&mm_l1_up>; }; down { pattern = <GESTURE_DOWN>; bindings = <&mm_l1_down>; }; left { pattern = <GESTURE_LEFT>; bindings = <&mm_l1_left>; }; right { pattern = <GESTURE_RIGHT>; bindings = <&mm_l1_right>; }; };
        zip_mouse_gesture_l2: zip_mouse_gesture_l2 { compatible = "zmk,input-processor-mouse-gesture"; #input-processor-cells = <0>; stroke-size = <60>; movement-threshold = <6>; idle-timeout-ms = <110>; gesture-cooldown-ms = <130>; enable-eager-mode; up { pattern = <GESTURE_UP>; bindings = <&mm_l2_up>; }; down { pattern = <GESTURE_DOWN>; bindings = <&mm_l2_down>; }; left { pattern = <GESTURE_LEFT>; bindings = <&mm_l2_left>; }; right { pattern = <GESTURE_RIGHT>; bindings = <&mm_l2_right>; }; };
        zip_mouse_gesture_l3: zip_mouse_gesture_l3 { compatible = "zmk,input-processor-mouse-gesture"; #input-processor-cells = <0>; stroke-size = <60>; movement-threshold = <6>; idle-timeout-ms = <110>; gesture-cooldown-ms = <130>; enable-eager-mode; up { pattern = <GESTURE_UP>; bindings = <&mm_l3_up>; }; down { pattern = <GESTURE_DOWN>; bindings = <&mm_l3_down>; }; left { pattern = <GESTURE_LEFT>; bindings = <&mm_l3_left>; }; right { pattern = <GESTURE_RIGHT>; bindings = <&mm_l3_right>; }; };
    };

    trackball_listener: trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;

        input-processors = <&tb_wheel_rema 1 1 &tb_hwheel_rema 1 1>;

        scroller_5 { layers = <5>; input-processors = <&tb_wheel_rema 1 1 &tb_hwheel_rema 1 1>; };

        /* layer15：カーソルだけ減速（例：1/4） */
        snipe_15 { layers = <15>; input-processors = <&tb_snipe_xy 1 4>; };

        gesture_e { layers = <7>; input-processors = <&zip_mouse_gesture_l11 &tb_drop_all 0 1>; };
        gesture_r { layers = <8>; input-processors = <&zip_mouse_gesture_l12 &tb_drop_all 0 1>; };
        gesture_s { layers = <9>; input-processors = <&zip_mouse_gesture_l13 &tb_drop_all 0 1>; };
        gesture_m { layers = <10>; input-processors = <&zip_mouse_gesture_l14 &tb_drop_all 0 1>; };
        gesture_t { layers = <11>; input-processors = <&zip_mouse_gesture_l7 &tb_drop_all 0 1>; };
        gesture_a { layers = <12>; input-processors = <&zip_mouse_gesture_l1 &tb_drop_all 0 1>; };
        gesture_d { layers = <13>; input-processors = <&zip_mouse_gesture_l2 &tb_drop_all 0 1>; };
        gesture_w { layers = <14>; input-processors = <&zip_mouse_gesture_l3 &tb_drop_all 0 1>; };
    };

    layer_listeners {
        compatible = "zmk,layer-listeners";
        gesture_auto { layers = <7 8 9 10 11 12 13 14>; bindings = <&mouse_gesture_on &mouse_gesture_off>; };
    };
};

&pinctrl {
    spi0_default: spi0_default { group1 { psels = <NRF_PSEL(SPIM_SCK, 0, 5) NRF_PSEL(SPIM_MOSI, 0, 4) NRF_PSEL(SPIM_MISO, 0, 4)>; }; };
    spi0_sleep: spi0_sleep { group1 { psels = <NRF_PSEL(SPIM_SCK, 0, 5) NRF_PSEL(SPIM_MOSI, 0, 4) NRF_PSEL(SPIM_MISO, 0, 4)>; low-power-enable; }; };
};

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        scroll-layers = <5>;
    };
};
