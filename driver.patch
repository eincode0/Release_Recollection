Subject: [PATCH] =?UTF-8?q?arrows-profiles:=208=E8=A6=81=E7=B4=A0=E2=86=92?=
 =?UTF-8?q?9=E8=A6=81=E7=B4=A0=E3=81=AB=E6=8B=A1=E5=BC=B5=EF=BC=88one=5Fsh?=
 =?UTF-8?q?ot=E3=83=95=E3=82=A3=E3=83=BC=E3=83=AB=E3=83=89=E8=BF=BD?=
 =?UTF-8?q?=E5=8A=A0=EF=BC=89?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- プロファイル形式を8要素から9要素に拡張
  [layer, up, down, left, right, tick, remainder, no_diagonal, one_shot]
- one_shot=1のとき、方向ごとに1回発火したら次の方向変化まで無視
- linux_key_to_zmk()にLANG1/LANG2を追加
  - LANG2（英数）: Linux keycode 58 → HID Usage 0x91
  - LANG1（かな）: Linux keycode 90 → HID Usage 0x90
- arrows-alt-profilesも同様に9要素に対応
- DTS/YMLのbindings説明を9要素形式に更新

https://claude.ai/code/session_014m5JA1EZWBZ96TdRuN2mvf
---
 dts/bindings/pixart,pmw3610-alt.yml | 15 ++++++----
 src/pixart.h                        |  4 +++
 src/pmw3610.c                       | 43 +++++++++++++++++++++++------
 3 files changed, 48 insertions(+), 14 deletions(-)

diff --git a/dts/bindings/pixart,pmw3610-alt.yml b/dts/bindings/pixart,pmw3610-alt.yml
index fed1b17..b19ac63 100644
--- a/dts/bindings/pixart,pmw3610-alt.yml
+++ b/dts/bindings/pixart,pmw3610-alt.yml
@@ -50,9 +50,12 @@ properties:
     type: array
     description: |
       レイヤーごとのキーマッピング。
-      5個ずつのセットで記述: [layer, key_up, key_down, key_left, key_right]
+      9個ずつのセットで記述:
+      [layer, key_up, key_down, key_left, key_right, tick, use_remainder, no_diagonal, one_shot]
       複数レイヤーを並べて書ける。
 
+      one_shot=1 のとき、方向ごとに1回発火したら次の方向変化まで無視する。
+
       Linux keycode早見表:
         矢印キー  UP=103 DOWN=108 LEFT=105 RIGHT=106
         PageUp/Down    104 / 109
@@ -60,11 +63,13 @@ properties:
         Enter          28
         Tab            15
         Escape         1
+        LANG2 (英数)   58
+        LANG1 (かな)   90
 
       例:
         arrows-profiles = <
-            3   103 108 105 106   /* layer 3: 矢印キー */
-            4   104 109 102 107   /* layer 4: PageUp/Down Home/End */
+            3   103 108 105 106  40  0  1  0  /* layer 3: 矢印キー */
+            4   104 109 102 107  40  0  1  0  /* layer 4: PageUp/Down Home/End */
         >;
   numpad-layers:
     type: array
@@ -187,7 +192,7 @@ properties:
     type: array
     description: |
       arrows_alt_mode が ON のときだけ有効なレイヤープロファイル。
-      8要素×Nプロファイル（arrows-profiles と同形式）:
-      [layer, key_up, key_down, key_left, key_right, tick_override, use_remainder, no_diagonal]
+      9要素×Nプロファイル（arrows-profiles と同形式）:
+      [layer, key_up, key_down, key_left, key_right, tick_override, use_remainder, no_diagonal, one_shot]
       zmk_keymap_layer_active() で判定するため最高レイヤーでなくても一致する。
       例: MOUSE レイヤー（4）で &arrows_alt 3 を保持中にレイヤー3のプロファイルを使う。
diff --git a/src/pixart.h b/src/pixart.h
index 2f7bad5..48b2c7c 100644
--- a/src/pixart.h
+++ b/src/pixart.h
@@ -59,6 +59,10 @@ struct pixart_data {
     uint32_t                     arrows_swapper_mod_usage;
     struct k_work_delayable      arrows_swapper_release_work;
 
+    /* arrows one-shot: suppress repeated fires in same direction until direction reverses */
+    bool                         arrows_one_shot_x_done;
+    bool                         arrows_one_shot_y_done;
+
     /* numpad 2-stroke input state */
     int32_t                      numpad_dx;
     int32_t                      numpad_dy;
diff --git a/src/pmw3610.c b/src/pmw3610.c
index b697458..ef5d7f8 100644
--- a/src/pmw3610.c
+++ b/src/pmw3610.c
@@ -68,15 +68,15 @@ static bool pmw3610_layer_match(const uint8_t *layers, size_t len) {
     return false;
 }
 
-/* arrows_profiles: flat array of uint16 groups [layer, up, down, left, right]
- * Returns pointer to the matching group (8 elements), or NULL if no match. */
+/* arrows_profiles: flat array of uint16 groups [layer, up, down, left, right, tick, remainder, no_diagonal, one_shot]
+ * Returns pointer to the matching group (9 elements), or NULL if no match. */
 static const uint16_t *pmw3610_arrows_profile_match(const struct pixart_config *config) {
     if (config->arrows_profiles == NULL || config->arrows_profiles_count == 0) {
         return NULL;
     }
     uint16_t active = (uint16_t)zmk_keymap_highest_layer_active();
     for (size_t i = 0; i < config->arrows_profiles_count; i++) {
-        const uint16_t *p = &config->arrows_profiles[i * 8];
+        const uint16_t *p = &config->arrows_profiles[i * 9];
         if (p[0] == active) {
             return p;
         }
@@ -97,7 +97,7 @@ static const uint16_t *pmw3610_arrows_alt_profile_match(const struct pixart_conf
         return NULL;
     }
     for (size_t i = 0; i < config->arrows_alt_profiles_count; i++) {
-        const uint16_t *p = &config->arrows_alt_profiles[i * 8];
+        const uint16_t *p = &config->arrows_alt_profiles[i * 9];
         if (zmk_keymap_layer_active((uint8_t)p[0])) {
             return p;
         }
@@ -437,6 +437,8 @@ static uint32_t linux_key_to_zmk(uint16_t linux_key) {
         case 1066: return HID_KB(0x6A); /* F15 (左のデスクトップ) */
         case 1067: return HID_KB(0x69); /* F14 (右のデスクトップ) */
         /* 1070/1071: swapper-style Cmd+Tab/Cmd+Shift+Tab — handled in pmw3610_send_arrow_key */
+        case 58:  return HID_KB(0x91); /* LANG2 (英数) */
+        case 90:  return HID_KB(0x90); /* LANG1 (かな) */
         default:  return 0;
     }
 #undef HID_KB
@@ -767,6 +769,8 @@ static int pmw3610_report_data(const struct device *dev) {
         data->snipe_dy = 0;
         data->arrows_dx = 0;
         data->arrows_dy = 0;
+        data->arrows_one_shot_x_done = false;
+        data->arrows_one_shot_y_done = false;
         data->last_poll_time = 0;
         data->last_x = 0;
         data->last_y = 0;
@@ -848,6 +852,8 @@ static int pmw3610_report_data(const struct device *dev) {
         data->scroll_dy = 0;
         data->arrows_dx = 0;
         data->arrows_dy = 0;
+        data->arrows_one_shot_x_done = false;
+        data->arrows_one_shot_y_done = false;
         data->last_poll_time = 0;
         data->last_x = 0;
         data->last_y = 0;
@@ -885,13 +891,14 @@ static int pmw3610_report_data(const struct device *dev) {
         }
     }
     if (profile != NULL) {
-        /* profile[0]=layer, [1]=up, [2]=down, [3]=left, [4]=right, [5]=tick(0=global), [6]=remainder, [7]=no_diagonal */
+        /* profile[0]=layer, [1]=up, [2]=down, [3]=left, [4]=right, [5]=tick(0=global), [6]=remainder, [7]=no_diagonal, [8]=one_shot */
         uint16_t key_up    = profile[1];
         uint16_t key_down  = profile[2];
         uint16_t key_left  = profile[3];
         uint16_t key_right = profile[4];
         bool use_remainder  = (profile[6] != 0);
         bool no_diagonal    = (profile[7] != 0);
+        bool one_shot       = (profile[8] != 0);
 
         data->scroll_dx = 0;
         data->scroll_dy = 0;
@@ -905,10 +912,12 @@ static int pmw3610_report_data(const struct device *dev) {
         if (data->arrows_dx != 0 && x != 0 &&
             ((data->arrows_dx > 0) != (x > 0))) {
             data->arrows_dx = 0;
+            data->arrows_one_shot_x_done = false;
         }
         if (data->arrows_dy != 0 && y != 0 &&
             ((data->arrows_dy > 0) != (y > 0))) {
             data->arrows_dy = 0;
+            data->arrows_one_shot_y_done = false;
         }
 
         data->arrows_dx += x;
@@ -947,18 +956,34 @@ static int pmw3610_report_data(const struct device *dev) {
         if ((no_diagonal || !config->arrows_diagonal) && fired_x && fired_y) {
             if (abs(x) >= abs(y)) {
                 fired_y = false;
+                emit_y = 0;
             } else {
                 fired_x = false;
+                emit_x = 0;
+            }
+        }
+
+        /* One-shot suppression: once fired in a direction, ignore until direction reverses */
+        if (one_shot) {
+            if (fired_x && data->arrows_one_shot_x_done) {
+                fired_x = false;
+                emit_x = 0;
+            }
+            if (fired_y && data->arrows_one_shot_y_done) {
+                fired_y = false;
+                emit_y = 0;
             }
         }
 
         uint16_t primary_key = 0;
-        if (fired_x) {
+        if (fired_x && emit_x != 0) {
             pmw3610_send_arrow_key(dev, emit_x);
+            if (one_shot) data->arrows_one_shot_x_done = true;
             primary_key = emit_x;
         }
-        if (fired_y) {
+        if (fired_y && emit_y != 0) {
             pmw3610_send_arrow_key(dev, emit_y);
+            if (one_shot) data->arrows_one_shot_y_done = true;
             if (!primary_key) primary_key = emit_y;
         }
 
@@ -1234,11 +1259,11 @@ static const struct sensor_driver_api pmw3610_driver_api = {
         .arrows_profiles = COND_CODE_1(DT_INST_NODE_HAS_PROP(n, arrows_profiles),  \
             (arrows_profiles_##n), (NULL)),                                         \
         .arrows_profiles_count = COND_CODE_1(DT_INST_NODE_HAS_PROP(n, arrows_profiles), \
-            (DT_INST_PROP_LEN(n, arrows_profiles) / 8), (0)),                      \
+            (DT_INST_PROP_LEN(n, arrows_profiles) / 9), (0)),                      \
         .arrows_alt_profiles = COND_CODE_1(DT_INST_NODE_HAS_PROP(n, arrows_alt_profiles), \
             (arrows_alt_profiles_##n), (NULL)),                                     \
         .arrows_alt_profiles_count = COND_CODE_1(DT_INST_NODE_HAS_PROP(n, arrows_alt_profiles), \
-            (DT_INST_PROP_LEN(n, arrows_alt_profiles) / 8), (0)),                  \
+            (DT_INST_PROP_LEN(n, arrows_alt_profiles) / 9), (0)),                  \
         .arrows_tick             = DT_PROP_OR(DT_DRV_INST(n), arrows_tick, 10),             \
         .arrows_diagonal         = DT_PROP(DT_DRV_INST(n), arrows_diagonal),                 \
         .arrows_accel            = DT_PROP(DT_DRV_INST(n), arrows_accel),                    \
-- 
2.43.0

