# ============================================================
# Recollection in-tree behaviors Kconfig
# ============================================================

config ZMK_BEHAVIOR_DRAG_LOCK
    bool "〈Drag Lock〉MB1 トグル behavior"
    default y
    depends on DT_HAS_ZMK_BEHAVIOR_DRAG_LOCK_ENABLED
    help
      Enable the drag-lock toggle behavior. One key tap engages MB1
      hold; another tap releases. Useful for long drags without
      requiring a held button.
